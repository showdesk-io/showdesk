# =============================================================================
# Showdesk .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python / Django
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_collected/

# Virtual environments
.venv/
venv/
env/
ENV/

# Django migrations (keep __init__.py)
# Uncomment the next line if you want to ignore migrations in development
# */migrations/

# Celery
celerybeat-schedule*
celerybeat.pid

# -----------------------------------------------------------------------------
# Node.js / JavaScript / TypeScript
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# Build output
frontend/dist/
widget/dist/
widget/build/

# TypeScript
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.pem
*.key
*.crt
credentials.json
service-account.json

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Dev orchestration
# -----------------------------------------------------------------------------
.dev-initialized
.tunnel.pid
.cloudflared/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.sass-cache/
*.css.map
*.js.map
business
