# Build stage
FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .
RUN npm run build

# Production stage
FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY --from=build /app/widget-demo.html /usr/share/nginx/html/widget-demo.html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
