{
  "name": "@showdesk/widget",
  "version": "0.1.2",
  "description": "Showdesk embeddable support widget — video-first bug reports",
  "type": "module",
  "main": "dist/widget.js",
  "module": "dist/widget.esm.js",
  "types": "dist/types/widget.d.ts",
  "exports": {
    ".": {
      "import": "./dist/widget.esm.js",
      "require": "./dist/widget.js",
      "types": "./dist/types/widget.d.ts"
    },
    "./widget.js": "./dist/widget.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c --environment BUILD:production && tsc --emitDeclarationOnly --declaration --declarationDir dist/types",
    "lint": "eslint src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/showdesk-io/showdesk.git",
    "directory": "widget"
  },
  "keywords": [
    "showdesk",
    "widget",
    "support",
    "screen-recording",
    "bug-report"
  ],
  "license": "AGPL-3.0",
  "homepage": "https://showdesk.io",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "rollup": "^4.24.0",
    "tslib": "^2.7.0",
    "typescript": "~5.6.0"
  }
}
