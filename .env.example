# =============================================================================
# Showdesk Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# -----------------------------------------------------------------------------
# Deployment
# -----------------------------------------------------------------------------
# Set to true to run migrations on deploy. Set to false for dry-run check.
RUN_MIGRATIONS=false
# Number of gunicorn workers (default: 4)
GUNICORN_WORKERS=4
# Number of celery worker processes (default: 4)
CELERY_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SUPERUSER_EMAIL=admin@showdesk.local
DJANGO_SUPERUSER_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://showdesk:showdesk@postgres:5432/showdesk
POSTGRES_DB=showdesk
POSTGRES_USER=showdesk
POSTGRES_PASSWORD=showdesk
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# S3-compatible Storage (MinIO for dev, Scaleway for prod)
# -----------------------------------------------------------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY_ID=showdesk
S3_SECRET_ACCESS_KEY=showdesk-secret
S3_BUCKET_NAME=showdesk-media
S3_REGION=us-east-1
S3_USE_SSL=False

# -----------------------------------------------------------------------------
# LiveKit (WebRTC / Screen Recording)
# -----------------------------------------------------------------------------
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# -----------------------------------------------------------------------------
# Video Processing
# -----------------------------------------------------------------------------
VIDEO_MAX_DURATION_SECONDS=600
VIDEO_MAX_FILE_SIZE_MB=500
VIDEO_EXPIRATION_DAYS=90
VIDEO_THUMBNAIL_WIDTH=320
VIDEO_THUMBNAIL_HEIGHT=180

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# Domain (used by Caddy for TLS in production)
# -----------------------------------------------------------------------------
SHOWDESK_DOMAIN=localhost

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost,https://localhost

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# For dev (console output):
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For prod with Mailjet API:
#   EMAIL_BACKEND=anymail.backends.mailjet.EmailBackend
# For prod with SMTP:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@showdesk.io

# Mailjet API (when using anymail.backends.mailjet.EmailBackend)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

# SMTP (when using django.core.mail.backends.smtp.EmailBackend)
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# -----------------------------------------------------------------------------
# OTP
# -----------------------------------------------------------------------------
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=600

# -----------------------------------------------------------------------------
# AI Features (off by default for self-hosted)
# -----------------------------------------------------------------------------
AI_ENABLED=False
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
# Optional: external AI API keys (user-provided)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_AI_TRANSCRIPTION=False
FEATURE_AI_TRIAGE=False
FEATURE_AI_SMART_REDACTION=False
FEATURE_AI_SENTIMENT_ANALYSIS=False

# -----------------------------------------------------------------------------
# Telemetry (opt-in only)
# -----------------------------------------------------------------------------
TELEMETRY_ENABLED=False
TELEMETRY_ENDPOINT=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=ws://localhost/ws
VITE_LIVEKIT_URL=ws://localhost:7880

# -----------------------------------------------------------------------------
# Widget
# -----------------------------------------------------------------------------
WIDGET_API_BASE_URL=/api/v1
